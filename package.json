{
  "name": "crm-monorepo",
  "private": true,
  "workspaces": [
    "chatty-api",
    "chatty-fe",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w chatty-api",
    "dev:frontend": "npm run dev -w chatty-fe",
    "build": "npm run build -ws --if-present",
    "typecheck": "npm run typecheck -w chatty-fe && npm run build -w chatty-api"
  }
}
