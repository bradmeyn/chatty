{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@chatty/shared-types": ["../packages/shared-types/src/index.ts"],
      "@/*": ["./src/*"],
      "@auth/*": ["./src/lib/features/auth/*"],
      "@clients/*": ["./src/lib/features/clients/*"],
      "@notes/*": ["./src/lib/features/notes/*"],
      "@components/*": ["./src/lib/components/*"],
      "@contexts/*": ["./src/lib/contexts/*"],
      "@hooks/*": ["./src/lib/hooks/*"],
      "@utils/*": ["./src/lib/utils/*"],
      "@schemas/*": ["./src/lib/schemas/*"],
      "@services/*": ["./src/lib/services/*"]
    }
  }
}
